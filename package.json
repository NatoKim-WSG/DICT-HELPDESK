{
    "name": "ione-helpdesk",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite dev",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "qa": "npm run lint && npm run test:unit && npm run build && npm audit --audit-level=high",
        "qa:full": "npm run qa && npm run test:e2e",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:e2e": "playwright test"
    },
    "devDependencies": {
        "@alpinejs/csp": "^3.15.11",
        "@axe-core/playwright": "^4.11.1",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.59.1",
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/postcss": "^4.2.1",
        "autoprefixer": "^10.5.0",
        "eslint": "^10.2.1",
        "globals": "^17.5.0",
        "laravel-vite-plugin": "^3.0.1",
        "postcss": "^8.5.9",
        "tailwindcss": "^4.2.1",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    }
}
